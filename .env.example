# ─── Database ───
DATABASE_URL=postgresql+asyncpg://postgres@127.0.0.1:5432/kb_manager

# ─── Embedding API (Ollama) ───
EMBEDDING_API_BASE=http://localhost:11434
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_TIMEOUT=30
EMBEDDING_BATCH_SIZE=10

# ─── Chunking ───
CHUNK_SIZE=500
CHUNK_OVERLAP=50
CHUNK_STRATEGY=fixed

# ─── Retrieve ───
RETRIEVE_TOP_K=5
RETRIEVE_DISTANCE_METRIC=cosine
RETRIEVE_SCORE_THRESHOLD=0.0

# ─── File Upload ───
FILE_MAX_SIZE_MB=50
FILE_ALLOWED_TYPES=txt,md,pdf,docx,csv,json,html

# ─── Server ───
HOST=0.0.0.0
PORT=8900
